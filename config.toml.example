[defaults]
lp_instance = "qastaging"
provider = "openrouter"

[auth]
openrouter_api_key = "sk-or-v1-..."
gemini_api_key = ""

[openrouter]
model = "openrouter/free"

[gemini]
model = ""

[[projects]]
lp_project = "charm-ceph-dashboard"
